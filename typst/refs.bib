@inproceedings{dasLLMBasedFaultDetection2025,
  title = {{{LLM-Based Fault Detection}} in {{Connected Vehicle Time-Series Data}}},
  booktitle = {Proceedings of the 2025 {{ACM Workshop}} on {{Secure}} and {{Trustworthy Cyber-physical Systems}}},
  author = {Das, Rakesh and Griffith, Henry and Rathore, Heena},
  year = 2025,
